# Loadout Pipeline Configuration
# Copy this file to .env and adjust values for your environment.
#
# Priority order (highest to lowest):
#   1. Environment variable set before the call:  MAX_UNZIP=4 bash bin/loadout-pipeline.sh
#   2. Values in .env (this file when copied)
#   3. Hardcoded fallback defaults in bin/loadout-pipeline.sh

# Number of parallel unzip workers.
MAX_UNZIP=2

# Temporary directory used for the job queue.
QUEUE_DIR=/tmp/iso_pipeline_queue
