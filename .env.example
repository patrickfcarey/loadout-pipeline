# Loadout Pipeline Configuration
# Copy this file to .env and adjust values for your environment.
#
# Priority order (highest to lowest):
#   1. Environment variable set before the call:  MAX_UNZIP=4 bash bin/loadout-pipeline.sh
#   2. Values in .env (this file when copied)
#   3. Hardcoded fallback defaults in lib/config.sh
#
# NOTE: Inline comments are NOT supported. The '#' character in a value is
# treated as a literal character, not a comment delimiter. This is intentional
# so that passwords and paths containing '#' are preserved without escaping.
#
#   Correct:  FTP_PASS=s3cr3t
#   Wrong:    MAX_UNZIP=2   # sets value to the string "2   # sets value to..."
#
# To add explanatory text, use a dedicated comment line (full line starting with #).

# =============================================================================
# POST-EXTRACTION STRIP LIST
# =============================================================================

# Path to a plain-text file listing exact filenames (one per line) to delete
# from every extracted archive directory before its contents are dispatched.
# Useful for removing download-site metadata files that you never want
# (e.g. "Vimm's Lair.txt"). Only top-level members are matched — paths
# containing '/' are rejected. Comments (#) and blank lines are ignored.
#
# Default: strip.list in the pipeline root directory.
# Set to an empty value or a non-existent path to disable stripping.
EXTRACT_STRIP_LIST=

# =============================================================================
# PIPELINE CORE
# =============================================================================

# Verbose debug logging. Strictly hierarchical; validated at load time —
# a typo ("DEBUG_IND=true") aborts startup with exit 2 rather than silently
# degrading to 0.
#   0 = silent (production default). Only log_info / log_warn / log_error
#       reach the operator.
#   1 = debug. Adds log_enter / log_debug / log_trace plus a RETURN trap
#       that logs every function exit in sourced libs.
#   2 = extended. Everything level 1 emits, plus log_cmd (exact external
#       command invocations), log_var (indirect variable dumps), log_fs
#       (filesystem mutations), log_xtrace (raw extended traces for
#       subprocess scripts). The RETURN trap also shows the function's
#       exit status so non-zero returns are visible without grepping.
#       Chatty; reach for level 2 only when localising a fault, not as a
#       daily default.
DEBUG_IND=0

# Number of parallel extract-stage workers (copy + 7z x → dispatch queue).
MAX_UNZIP=2

# Number of parallel dispatch-stage workers (drain dispatch queue → adapter).
MAX_DISPATCH=2

# Root directory for all pipeline scratch I/O. Point this at a fast disk
# (NVMe, SSD, ramdisk) to speed up extraction and dispatch. EXTRACT_DIR,
# COPY_DIR, and QUEUE_DIR all default to subdirectories under this path.
# You can still override any of the three individually if needed.
SCRATCH_DISK_DIR=/tmp

# Parent directory for the file-based queues. The pipeline creates two
# sub-queues inside it: "$QUEUE_DIR/extract" and "$QUEUE_DIR/dispatch".
# The space ledger and worker registry also live here.
# Default: $SCRATCH_DISK_DIR/iso_pipeline_queue
QUEUE_DIR=/tmp/iso_pipeline_queue

# Directory where ISOs are extracted during processing.
# Default: $SCRATCH_DISK_DIR/iso_pipeline
EXTRACT_DIR=/tmp/iso_pipeline

# Parent of the per-run scratch spool. Each pipeline run claims its own
# subdir "$COPY_DIR/$$" (exported as COPY_SPOOL) so concurrent runs never
# collide. A startup sweep removes subdirs whose PID is no longer alive.
# Default: $SCRATCH_DISK_DIR/iso_pipeline_copies
COPY_DIR=/tmp/iso_pipeline_copies

# Percent overhead added to the raw (archive + extracted) byte requirement
# when reserving scratch space. 20 means "reserve × 1.20".
SPACE_OVERHEAD_PCT=20

# Max number of intra-run recovery passes after SIGKILL'd workers leave
# orphaned jobs. After this many attempts, remaining orphans are considered
# permanently abandoned and the pipeline returns non-zero.
MAX_RECOVERY_ATTEMPTS=3

# Dispatch worker poll backoff when the dispatch queue is momentarily empty.
# INITIAL is the starting sleep; MAX is the exponential ceiling (both in ms).
DISPATCH_POLL_INITIAL_MS=50
DISPATCH_POLL_MAX_MS=500

# Space-reservation retry backoff for extract workers.
# When a worker cannot reserve scratch space (because a sibling is using it),
# it sleeps this many seconds before re-queuing the job. The interval doubles
# on each consecutive miss for the same job, capped at the MAX value.
# Example: a 60 GB archive held by another worker would cause retries at
# 5s → 10s → 20s → 40s → 60s → 60s → ... until space is released.
# If the filesystem is provably too small (no siblings hold any space at all),
# the job fails immediately rather than waiting.
SPACE_RETRY_BACKOFF_INITIAL_SEC=5
SPACE_RETRY_BACKOFF_MAX_SEC=60

# =============================================================================
# FTP ADAPTER  (adapters/ftp.sh)
# =============================================================================

FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_PORT=21

# =============================================================================
# HDL DUMP ADAPTER  (adapters/hdl_dump.sh)
# =============================================================================
#
# The hdl adapter extends the standard 3-field job line with one extra field:
#   ~<iso>|hdl|<cd|dvd>|<title>~
# Per-job fields are the disc format and the PS2 title name. Everything else
# — which HDD to write to — is an operator-wide env var below, resolved by
# the operator's own ~/.hdl_dump.conf. The adapter does NOT rewrite HOME or
# fabricate a scratch config.

# Path to the hdl_dump binary. Defaults to 'hdl_dump' (assumes it is on PATH).
HDL_DUMP_BIN=hdl_dump

# Host-side HDD device id used for the startup writability probe. This is
# typically the physical device your machine exposes for the PS2 disk
# (e.g. "sri:" on Linux when the HDD is attached via USB/SATA). When set and
# any hdl job is queued, the pipeline runs `hdl_dump toc $HDL_HOST_DEVICE`
# once before doing any work so a misconfigured device fails fast. Leave
# empty to skip the probe.
HDL_HOST_DEVICE=

# hdl_dump target passed to inject_cd / inject_dvd for every hdl job
# (e.g. "hdd0:"). hdl_dump resolves this id via the operator's own
# ~/.hdl_dump.conf. Required whenever the jobs file contains any hdl entry.
HDL_INSTALL_TARGET=

# =============================================================================
# LOCAL VOLUME ADAPTER  (adapters/lvol.sh)
# =============================================================================

# Mount point of the local volume (SD card, USB drive, NVMe, SSD, HDD, etc).
# Must be mounted and writable before running.
LVOL_MOUNT_POINT=/mnt/lvol

# =============================================================================
# RCLONE ADAPTER  (adapters/rclone.sh)
# =============================================================================

# Remote name as configured in `rclone config` (include the trailing colon).
RCLONE_REMOTE=
# Base path on the remote; the job's destination is appended to this.
RCLONE_DEST_BASE=
# Extra flags passed through to `rclone copy`.
RCLONE_FLAGS=
# Path to rclone config file (optional; uses default if unset).
RCLONE_CONFIG=

# =============================================================================
# RSYNC ADAPTER  (adapters/rsync.sh)
# =============================================================================

# Base path prepended to the job's destination.
RSYNC_DEST_BASE=
# Remote host. Leave empty for a local rsync target.
RSYNC_HOST=
RSYNC_USER=
RSYNC_SSH_PORT=22
# Extra flags passed through to `rsync`.
RSYNC_FLAGS=
